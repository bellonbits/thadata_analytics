# ── Copy this to .env and fill in real values ──────────────────────────────

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_CONTENT=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_GRADING=meta-llama/llama-4-scout-17b-16e-instruct

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL here once deployed, e.g.:
# CORS_ORIGINS=https://thadata.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Storage (Railway persistent volume will be mounted at /data)
UPLOAD_DIR=/data/uploads
DATA_DIR=/data/db
MAX_UPLOAD_MB=50
